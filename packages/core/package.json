{
  "name": "@codemation/core",
  "version": "0.12.0",
  "publishConfig": {
    "access": "public"
  },
  "author": "Made Relevant B.V.",
  "homepage": "https://www.maderelevant.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/MadeRelevant/codemation",
    "directory": "packages/core"
  },
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "development": "./src/browser.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs"
    },
    "./contracts": {
      "types": "./dist/contracts.d.ts",
      "development": "./src/contracts.ts",
      "import": "./dist/contracts.js",
      "require": "./dist/contracts.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "development": "./src/testing.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    },
    "./bootstrap": {
      "types": "./dist/bootstrap/index.d.ts",
      "development": "./src/bootstrap/index.ts",
      "import": "./dist/bootstrap/index.js",
      "require": "./dist/bootstrap/index.cjs"
    }
  },
  "scripts": {
    "changeset:verify": "pnpm --workspace-root run changeset:verify",
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "pnpm build && vitest run",
    "test:unit": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "tsdown": "^0.15.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "4.0.18"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "zod": "^4.3.6"
  }
}
