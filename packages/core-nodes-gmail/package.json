{
  "name": "@codemation/core-nodes-gmail",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "codemation": {
    "plugin": {
      "kind": "plugin",
      "entry": "./dist/index.js",
      "exportName": "GmailNodes"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": {
        "import": "./src/index.ts",
        "require": "./dist/index.cjs"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./codemation-plugin": {
      "types": "./src/codemationPluginRegistry.ts",
      "import": "./src/codemationPluginRegistry.ts"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "pnpm build && node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@codemation/core": "workspace:*",
    "@google-cloud/pubsub": "^5.2.0",
    "googleapis": "^163.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "tsdown": "^0.15.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
