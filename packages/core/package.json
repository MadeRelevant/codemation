{
  "name": "@codemation/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": {
        "import": "./src/index.ts",
        "require": "./dist/index.cjs"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./src/browser.ts",
      "import": "./src/browser.ts"
    }
  },
  "scripts": {
    "dev": "tsc -p tsconfig.json --noEmit --watch",
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "pnpm build && node --import tsx --test test/**/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "tsdown": "^0.15.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "zod": "^4.3.6"
  }
}
