{
  "$schema": "https://turbo.build/schema.json",
  "concurrency": "12",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "prisma:generate": {
      "dependsOn": [],
      "outputs": ["src/infrastructure/persistence/generated/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck", "@codemation/host#prisma:generate"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    }
  }
}
