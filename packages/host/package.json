{
  "name": "@codemation/host",
  "version": "0.0.5",
  "publishConfig": {
    "access": "public"
  },
  "author": "Made Relevant B.V.",
  "homepage": "https://www.maderelevant.com",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": {
        "import": "./src/index.ts"
      },
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "development": {
        "import": "./src/client.ts"
      },
      "import": "./dist/client.js"
    },
    "./credentials": {
      "types": "./dist/credentials.d.ts",
      "development": {
        "import": "./src/credentials.ts"
      },
      "import": "./dist/credentials.js"
    },
    "./consumer": {
      "types": "./dist/consumer.d.ts",
      "development": {
        "import": "./src/consumer.ts"
      },
      "import": "./dist/consumer.js"
    },
    "./next/server": {
      "types": "./dist/nextServer.d.ts",
      "development": {
        "import": "./src/nextServer.ts"
      },
      "import": "./dist/nextServer.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "development": {
        "import": "./src/server.ts"
      },
      "import": "./dist/server.js"
    },
    "./dev-server-sidecar": {
      "types": "./dist/devServerSidecar.d.ts",
      "development": {
        "import": "./src/devServerSidecar.ts"
      },
      "import": "./dist/devServerSidecar.js"
    },
    "./persistence": {
      "types": "./dist/persistenceServer.d.ts",
      "development": {
        "import": "./src/persistenceServer.ts"
      },
      "import": "./dist/persistenceServer.js"
    }
  },
  "scripts": {
    "prisma:generate": "prisma generate && node ./scripts/ensure-prisma-runtime-sourcemaps.mjs",
    "build": "tsdown src/index.ts src/client.ts src/credentials.ts src/consumer.ts src/nextServer.ts src/server.ts src/devServerSidecar.ts src/persistenceServer.ts --out-dir dist --sourcemap",
    "dev": "tsdown src/index.ts src/client.ts src/credentials.ts src/consumer.ts src/nextServer.ts src/server.ts src/devServerSidecar.ts src/persistenceServer.ts --out-dir dist --sourcemap --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "pnpm -w exec concurrently -m 5 -c auto -n unit,integration,ui,browser,e2e \"pnpm run test:unit\" \"pnpm run test:integration\" \"pnpm run test:ui\" \"pnpm run test:browser\" \"pnpm run test:e2e\"",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:ui": "vitest run --config vitest.ui.config.ts",
    "test:browser": "pnpm exec tsx test/playwright/scripts/run-browser-e2e.ts",
    "test:browser:install": "playwright install chromium",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "coverage": "pnpm -w run coverage",
    "coverage:credentials": "vitest run --config vitest.unit.config.ts test/credentialsScreen.test.tsx --coverage --coverage.provider=v8 --coverage.reporter=text-summary --coverage.reporter=text --coverage.reportsDirectory=./coverage/credentials-unit --coverage.include=../next-host/src/features/credentials/CredentialsScreen.tsx && vitest run --config vitest.integration.config.ts test/http/credentialInstances.integration.test.ts --coverage --coverage.provider=v8 --coverage.reporter=text-summary --coverage.reporter=text --coverage.reportsDirectory=./coverage/credentials-integration --coverage.include=src/presentation/http/routeHandlers/CredentialHttpRouteHandler.ts --coverage.include=src/presentation/http/routeHandlers/OAuth2HttpRouteHandler.ts --coverage.include=src/application/commands/CredentialCommandHandlers.ts --coverage.include=src/application/queries/CredentialQueryHandlers.ts --coverage.include=src/domain/credentials/**/*.ts --coverage.include=src/infrastructure/persistence/CredentialPersistenceStore.ts"
  },
  "dependencies": {
    "@auth/core": "^0.34.3",
    "@codemation/core": "workspace:*",
    "@codemation/core-nodes": "workspace:*",
    "@codemation/eventbus-redis": "workspace:*",
    "@electric-sql/pglite": "^0.4.2",
    "@electric-sql/pglite-socket": "^0.1.2",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@prisma/client-runtime-utils": "^7.5.0",
    "@tanstack/react-query": "^5.90.21",
    "@types/bcryptjs": "^3.0.0",
    "@uiw/react-json-view": "2.0.0-alpha.41",
    "@xyflow/react": "^12.10.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.58.3",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "hono": "^4.12.8",
    "jose": "^6.2.2",
    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "next-auth": "^4.24.13",
    "pg": "^8.16.3",
    "pglite-prisma-adapter": "^0.7.2",
    "pretty-ms": "^9.3.0",
    "prisma": "^7.0.0",
    "rc-tree": "^5.13.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "react-use-websocket": "^4.13.0",
    "reflect-metadata": "^0.2.2",
    "sanitize-filename": "^1.6.4",
    "serialize-javascript": "^7.0.4",
    "tsx": "^4.21.0",
    "ws": "^8.19.0",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@codemation/core-nodes-gmail": "workspace:*",
    "@playwright/test": "^1.58.2",
    "@tanstack/react-router": "^1.167.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dagre": "^0.7.54",
    "@types/node": "^25.3.5",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/serialize-javascript": "^5.0.4",
    "@types/ws": "^8.18.1",
    "@types/zxcvbn": "^4.4.5",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.3",
    "jsdom": "^28.1.0",
    "monocart-coverage-reports": "^2.12.9",
    "monocart-reporter": "^2.10.0",
    "testcontainers": "^10.28.0",
    "tsdown": "^0.15.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
