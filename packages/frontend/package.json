{
  "name": "@codemation/frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./src/client.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts"
    },
    "./templates": {
      "types": "./src/templates.ts",
      "import": "./src/templates.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@codemation/core": "workspace:*",
    "@codemation/eventbus-redis": "workspace:*",
    "@codemation/queue-bullmq": "workspace:*",
    "@codemation/run-store-sqlite": "workspace:*",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.166.7",
    "@tanstack/react-start": "^1.166.7",
    "@uiw/react-json-view": "2.0.0-alpha.41",
    "@xyflow/react": "^12.10.1",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "rc-tree": "^5.13.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-use-websocket": "^4.13.0",
    "reflect-metadata": "^0.2.2",
    "tsx": "^4.21.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@codemation/core-nodes": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dagre": "^0.7.54",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "eslint": "^10.0.3",
    "jsdom": "^28.1.0",
    "tsdown": "^0.15.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
