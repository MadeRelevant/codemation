{
  "name": "@codemation/runtime-dev",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/bin.js",
  "types": "./dist/bin.d.ts",
  "bin": {
    "codemation-runtime-dev": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsdown src/bin.ts --out-dir dist --sourcemap",
    "dev": "tsdown src/bin.ts --out-dir dist --sourcemap --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@codemation/core": "workspace:*",
    "@codemation/host": "workspace:*",
    "@hono/node-server": "^1.19.9",
    "hono": "^4.12.8",
    "reflect-metadata": "^0.2.2",
    "vite": "^6.3.5",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@codemation/eslint-config": "workspace:*",
    "@types/node": "^25.3.5",
    "@types/ws": "^8.18.1",
    "eslint": "^10.0.3",
    "tsdown": "^0.15.5",
    "typescript": "^5.9.3",
    "vitest": "4.0.18"
  }
}
