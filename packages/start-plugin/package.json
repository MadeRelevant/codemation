{
  "name": "@codemation/start-plugin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./virtual-modules": {
      "types": "./src/virtual-modules.d.ts"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --out-dir dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@codemation/frontend": "workspace:*",
    "@tanstack/react-router": "^1.166.7",
    "@tanstack/react-start": "^1.166.7",
    "@tanstack/virtual-file-routes": "^1.161.4",
    "pathe": "^2.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "tsdown": "^0.15.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "peerDependencies": {
    "vite": ">=7.0.0"
  }
}
