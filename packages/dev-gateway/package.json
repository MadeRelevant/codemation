{
  "name": "@codemation/dev-gateway",
  "version": "0.0.5",
  "publishConfig": {
    "access": "public"
  },
  "author": "Made Relevant B.V.",
  "homepage": "https://www.maderelevant.com",
  "type": "module",
  "main": "./dist/bin.js",
  "scripts": {
    "build": "tsdown src/bin.ts --out-dir dist --sourcemap",
    "dev": "tsdown src/bin.ts --out-dir dist --sourcemap --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@codemation/host": "workspace:*",
    "http-proxy": "^1.18.1",
    "reflect-metadata": "^0.2.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@codemation/eslint-config": "workspace:*",
    "@types/http-proxy": "^1.17.15",
    "@types/node": "^25.3.5",
    "@types/ws": "^8.18.1",
    "eslint": "^10.0.3",
    "tsdown": "^0.15.5",
    "typescript": "^5.9.3",
    "vitest": "4.0.18"
  }
}
