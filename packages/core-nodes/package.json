{
  "name": "@codemation/core-nodes",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "tsc -p tsconfig.json --noEmit --watch",
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "pnpm --filter @codemation/core build && pnpm build && node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@codemation/core": "workspace:*",
    "@langchain/core": "^1.1.31",
    "@langchain/openai": "^1.2.12",
    "lucide-react": "^0.577.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "tsdown": "^0.15.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  }
}
