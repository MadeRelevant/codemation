    "type": "git",
    "url": "https://github.com/MadeRelevant/codemation",
    "directory": "packages/canvas"
  },
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "changeset:verify": "pnpm --workspace-root run changeset:verify",
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test:unit": "vitest run --config vitest.ui.config.ts --passWithNoTests",
    "test:ui": "vitest run --config vitest.ui.config.ts"
  },
  "dependencies": {
    "@codemation/canvas-core": "workspace:*",
    "@codemation/core": "workspace:*",
    "@codemation/host": "workspace:*",
    "@codemation/ui": "workspace:*",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.90.21",
    "aria-hidden": "^1.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "monaco-editor": "^0.55.1",
    "pretty-ms": "^9.3.0",
    "radix-ui": "^1.4.3",
    "react-remove-scroll": "^2.7.2",
    "tailwind-merge": "^3.5.0"
  },
  "sideEffects": false,
  "peerDependencies": {
    "@headless-tree/core": "*",
    "@headless-tree/react": "*",
    "@uiw/react-json-view": "*",
    "@xyflow/react": "*",
    "elkjs": "*",
    "lucide-react": "*",
    "react": "*",
    "react-dom": "*",
    "recharts": "*",
    "simple-icons": "*"
  },
  "devDependencies": {
    "@headless-tree/core": "^1.6.3",
    "@headless-tree/react": "^1.6.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.5",
    "@types/react": "*",
    "@types/react-dom": "^19.2.3",
    "@uiw/react-json-view": "2.0.0-alpha.41",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^10.0.3",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "recharts": "^3.8.1",
    "simple-icons": "^16.12.0",
    "tailwind-merge": "^3.5.0",
    "tsdown": "^0.15.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
