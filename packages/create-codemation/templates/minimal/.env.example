# Default: PGlite under .codemation/pglite (omit DATABASE_URL).
# Optional TCP Postgres: DATABASE_URL=postgresql://user:password@127.0.0.1:5432/codemation

# BullMQ requires DATABASE_URL + PostgreSQL (not PGlite):
# REDIS_URL=redis://127.0.0.1:6379
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/codemation

# Local-development defaults for auth and credential encryption. Rotate these before sharing or deploying.
CODEMATION_CREDENTIALS_MASTER_KEY=codemation-local-dev-credentials-master-key
AUTH_SECRET=codemation-local-dev-auth-secret
