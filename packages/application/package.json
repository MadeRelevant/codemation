{
  "name": "@codemation/application",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "dev:lib": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint .",
    "test": "echo \"(test placeholder)\""
  },
  "dependencies": {
    "@codemation/core": "workspace:*",
    "@codemation/eventbus-redis": "workspace:*",
    "@codemation/queue-bullmq": "workspace:*",
    "@codemation/run-store-sqlite": "workspace:*",
    "@tanstack/react-query": "^5.90.21",
    "@uiw/react-json-view": "2.0.0-alpha.41",
    "@xyflow/react": "^12.10.1",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "rc-tree": "^5.13.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-use-websocket": "^4.13.0",
    "reflect-metadata": "^0.2.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.54",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "eslint": "^10.0.3",
    "eslint-config-next": "^16.1.6",
    "tsdown": "^0.15.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
