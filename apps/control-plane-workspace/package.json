{
  "name": "control-plane-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "codemation": "node ../../tooling/scripts/run-codemation-tsx.mjs ../../packages/cli/src/bin.ts ../../tsconfig.codemation-tsx.json",
    "dev": "pnpm codemation dev --watch-framework",
    "worker": "pnpm codemation serve worker",
    "build": "pnpm --filter @codemation/cli build && node ../../packages/cli/bin/codemation.js build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@codemation/cli": "workspace:*",
    "@codemation/core": "workspace:*",
    "@codemation/core-nodes": "workspace:*",
    "@codemation/core-nodes-gmail": "workspace:*",
    "@codemation/host": "workspace:*",
    "dotenv": "^17.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "4.0.18"
  }
}
