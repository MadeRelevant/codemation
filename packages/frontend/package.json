{
  "name": "@codemation/frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": {
        "import": "./src/index.ts"
      },
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "development": {
        "import": "./src/client.ts"
      },
      "import": "./dist/client.js"
    },
    "./credentials": {
      "types": "./dist/credentials.d.ts",
      "development": {
        "import": "./src/credentials.ts"
      },
      "import": "./dist/credentials.js"
    },
    "./consumer": {
      "types": "./dist/consumer.d.ts",
      "development": {
        "import": "./src/consumer.ts"
      },
      "import": "./dist/consumer.js"
    },
    "./next/client": {
      "types": "./dist/nextClient.d.ts",
      "development": {
        "import": "./src/nextClient.ts"
      },
      "import": "./dist/nextClient.js"
    },
    "./next/server": {
      "types": "./dist/nextServer.d.ts",
      "development": {
        "import": "./src/nextServer.ts"
      },
      "import": "./dist/nextServer.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "development": {
        "import": "./src/server.ts"
      },
      "import": "./dist/server.js"
    },
    "./vite": {
      "types": "./src/vite.ts",
      "import": "./vite.js"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts src/client.ts src/credentials.ts src/consumer.ts src/nextClient.ts src/nextServer.ts src/server.ts --out-dir dist --sourcemap",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "pnpm run test:unit && pnpm run test:integration && pnpm run test:e2e",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "coverage": "pnpm run coverage:integration",
    "coverage:integration": "vitest run --config vitest.integration.coverage.config.ts"
  },
  "dependencies": {
    "@codemation/core": "workspace:*",
    "@codemation/eventbus-redis": "workspace:*",
    "@codemation/queue-bullmq": "workspace:*",
    "@fastify/static": "^9.0.0",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@prisma/client-runtime-utils": "^7.5.0",
    "@tanstack/react-query": "^5.90.21",
    "@uiw/react-json-view": "2.0.0-alpha.41",
    "@vitejs/plugin-react": "^5.1.4",
    "@xyflow/react": "^12.10.1",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "fastify": "^5.8.2",
    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "pg": "^8.16.3",
    "pretty-ms": "^9.3.0",
    "prisma": "^7.0.0",
    "rc-tree": "^5.13.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "react-use-websocket": "^4.13.0",
    "reflect-metadata": "^0.2.2",
    "tsx": "^4.21.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@codemation/core-nodes": "workspace:*",
    "@codemation/core-nodes-gmail": "workspace:*",
    "@tanstack/react-router": "^1.167.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dagre": "^0.7.54",
    "@types/node": "^25.3.5",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.3",
    "jsdom": "^28.1.0",
    "testcontainers": "^10.28.0",
    "tsdown": "^0.15.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
