{
  "name": "@codemation/core-nodes-gmail",
  "version": "0.0.9",
  "publishConfig": {
    "access": "public"
  },
  "author": "Made Relevant B.V.",
  "homepage": "https://www.maderelevant.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maderelevant/codemation.git",
    "directory": "packages/core-nodes-gmail"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "codemation": {
    "plugin": {
      "kind": "plugin",
      "entry": "./dist/index.js",
      "exportName": "GmailNodes"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": {
        "import": "./src/index.ts",
        "require": "./dist/index.cjs"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./codemation-plugin": {
      "types": "./src/codemationPluginRegistry.ts",
      "import": "./src/codemationPluginRegistry.ts"
    },
    "./nodes/OnNewGmailTrigger": {
      "types": "./src/nodes/OnNewGmailTrigger.ts",
      "development": {
        "import": "./src/nodes/OnNewGmailTrigger.ts",
        "require": "./dist/index.cjs"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "pnpm build && vitest run"
  },
  "dependencies": {
    "@codemation/core": "workspace:*",
    "googleapis": "^163.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "tsdown": "^0.15.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "4.0.18"
  }
}
