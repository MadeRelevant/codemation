{
  "name": "codemation",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "codemation": "node tooling/scripts/run-codemation-tsx.mjs packages/cli/src/bin.ts tsconfig.codemation-tsx.json",
    "dev": "pnpm run dev:framework",
    "dev:docs": "pnpm --filter @codemation/docs dev",
    "dev:framework": "concurrently --raw --kill-others-on-fail -n host,test-dev \"pnpm --filter @codemation/host dev\" \"pnpm --filter @codemation/test-dev dev\"",
    "dev:framework:warm": "pnpm run dev:framework",
    "dev:plugin": "pnpm --filter @codemation/plugin-dev dev:packaged",
    "dev:plugin:framework": "pnpm --filter @codemation/plugin-dev dev:framework",
    "dev:consumer": "pnpm --filter @codemation/test-dev dev",
    "analyze": "pnpm --filter @codemation/next-host analyze",
    "e2e:devserver": "pnpm exec turbo run build --filter=@codemation/e2e-app... --filter=!@codemation/next-host --filter=!@codemation/eslint-config && pnpm --filter @codemation/e2e-app dev",
    "e2e:serve-web": "pnpm --filter @codemation/e2e-app exec codemation serve web",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint:eslint": "turbo run lint",
    "lint:repo": "pnpm run dupcheck && pnpm run antipatterns",
    "lint:circular": "node tooling/scripts/check-circular-deps.mjs",
    "lint:knip": "pnpm exec knip --no-progress --reporter compact",
    "lint": "pnpm run lint:eslint && pnpm run lint:repo && pnpm run lint:circular",
    "depcruise": "pnpm exec depcruise --config .dependency-cruiser.cjs packages/next-host/src",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm run check:metadata",
    "check:metadata": "tsx tooling/scripts/check-curated-package-metadata.ts",
    "precommit": "pnpm run lint:eslint && pnpm typecheck && pnpm exec turbo run test:unit ${TURBO_FILTER:-}",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo run build && pnpm run test:suites",
    "test:suites": "concurrently -m 2 -c auto -n unit,integration,ui,browser,e2e \"pnpm run test:unit\" \"pnpm run test:integration\" \"pnpm run test:ui\" \"pnpm run test:browser\" \"pnpm run test:e2e\"",
    "test:unit": "vitest run --config tooling/vitest/unit.config.ts",
    "test:integration": "vitest run --config tooling/vitest/integration.config.ts",
    "test:ui": "vitest run --config tooling/vitest/ui.config.ts",
    "test:browser": "timeout 30m pnpm --filter @codemation/host run test:browser",
    "test:e2e": "vitest run --config tooling/vitest/e2e.config.ts",
    "coverage": "pnpm run coverage:clean && concurrently -m 2 -c auto --kill-others-on-fail false -n unit,integration,ui,browser,e2e \"pnpm run coverage:unit\" \"pnpm run coverage:integration\" \"pnpm run coverage:ui\" \"pnpm run coverage:browser\" \"pnpm run coverage:e2e\"; pnpm run coverage:merge",
    "coverage:clean": "pnpm exec rimraf coverage",
    "coverage:unit": "vitest run --config tooling/vitest/unit.config.ts --coverage --coverage.provider=v8 --coverage.reporter=lcov --coverage.reportsDirectory=coverage/raw/unit --coverage.reportOnFailure --coverage.exclude='**/test/**' --coverage.exclude='**/prisma-generated/**' --coverage.exclude='**/*.config.{ts,mjs,js}' --coverage.exclude='**/src/bootstrap/runtime/**' --coverage.exclude='**/src/bootstrap/CodemationBootstrapRequest.ts' --coverage.exclude='**/src/bootstrap/CodemationContainerRegistrationRegistrar.ts' --coverage.exclude='**/src/bootstrap/CodemationRuntimeUrlResolver.ts' --coverage.exclude='**/src/infrastructure/collections/Sqlite*' --coverage.exclude='**/src/infrastructure/scheduler/bullmq/**' --coverage.exclude='**/src/presentation/server/CodemationTsyringe*' --coverage.exclude='**/src/infrastructure/persistence/Prisma*' --coverage.exclude='**/src/audit/PrismaWorkflowAuditLogRepository.ts' --coverage.exclude='**/src/server/CodemationNextHost.ts' --coverage.exclude='**/src/server/NextHostPackageRootResolver.ts' --coverage.exclude='**/src/auth/EdgeSessionVerifier.ts' --coverage.exclude='**/src/consumer/ConsumerOutputBuilder.ts' --coverage.exclude='**/src/dev/CliDevProxyServer.ts' --coverage.exclude='**/src/credentials/Broker*' --coverage.exclude='**/src/pairing/**' --coverage.exclude='**/src/application/commands/UpsertLocalBootstrapUserCommand.ts' --coverage.exclude='**/src/infrastructure/persistence/CodemationPostgres*.ts' --coverage.exclude='**/src/canvas/WorkflowCanvasStraightCountEdge.tsx' --coverage.exclude='**/src/canvas/WorkflowCanvasSymmetricForkEdge.tsx' --coverage.exclude='**/src/canvas/WorkflowCanvasSimpleIconGlyph.tsx'",
    "coverage:integration": "vitest run --config tooling/vitest/integration.config.ts --coverage --coverage.provider=v8 --coverage.reporter=lcov --coverage.reportsDirectory=coverage/raw/integration --coverage.reportOnFailure --coverage.exclude='**/test/**' --coverage.exclude='**/prisma-generated/**' --coverage.exclude='**/*.config.{ts,mjs,js}' --coverage.exclude='**/src/bootstrap/runtime/**' --coverage.exclude='**/src/bootstrap/CodemationBootstrapRequest.ts' --coverage.exclude='**/src/bootstrap/CodemationContainerRegistrationRegistrar.ts' --coverage.exclude='**/src/bootstrap/CodemationRuntimeUrlResolver.ts' --coverage.exclude='**/src/infrastructure/collections/Sqlite*' --coverage.exclude='**/src/infrastructure/scheduler/bullmq/**' --coverage.exclude='**/src/presentation/server/CodemationTsyringe*' --coverage.exclude='**/src/infrastructure/persistence/Prisma*' --coverage.exclude='**/src/audit/PrismaWorkflowAuditLogRepository.ts' --coverage.exclude='**/src/server/CodemationNextHost.ts' --coverage.exclude='**/src/server/NextHostPackageRootResolver.ts' --coverage.exclude='**/src/auth/EdgeSessionVerifier.ts' --coverage.exclude='**/src/consumer/ConsumerOutputBuilder.ts' --coverage.exclude='**/src/dev/CliDevProxyServer.ts' --coverage.exclude='**/src/credentials/Broker*' --coverage.exclude='**/src/pairing/**' --coverage.exclude='**/src/application/commands/UpsertLocalBootstrapUserCommand.ts' --coverage.exclude='**/src/infrastructure/persistence/CodemationPostgres*.ts' --coverage.exclude='**/src/canvas/WorkflowCanvasStraightCountEdge.tsx' --coverage.exclude='**/src/canvas/WorkflowCanvasSymmetricForkEdge.tsx' --coverage.exclude='**/src/canvas/WorkflowCanvasSimpleIconGlyph.tsx'",
    "coverage:ui": "vitest run --config tooling/vitest/ui.config.ts --coverage --coverage.provider=v8 --coverage.reporter=lcov --coverage.reportsDirectory=coverage/raw/ui --coverage.reportOnFailure --coverage.exclude='**/test/**' --coverage.exclude='**/prisma-generated/**' --coverage.exclude='**/*.config.{ts,mjs,js}' --coverage.exclude='**/src/bootstrap/runtime/**' --coverage.exclude='**/src/bootstrap/CodemationBootstrapRequest.ts' --coverage.exclude='**/src/bootstrap/CodemationContainerRegistrationRegistrar.ts' --coverage.exclude='**/src/bootstrap/CodemationRuntimeUrlResolver.ts' --coverage.exclude='**/src/infrastructure/collections/Sqlite*' --coverage.exclude='**/src/infrastructure/scheduler/bullmq/**' --coverage.exclude='**/src/presentation/server/CodemationTsyringe*' --coverage.exclude='**/src/infrastructure/persistence/Prisma*' --coverage.exclude='**/src/audit/PrismaWorkflowAuditLogRepository.ts' --coverage.exclude='**/src/server/CodemationNextHost.ts' --coverage.exclude='**/src/server/NextHostPackageRootResolver.ts' --coverage.exclude='**/src/auth/EdgeSessionVerifier.ts' --coverage.exclude='**/src/consumer/ConsumerOutputBuilder.ts' --coverage.exclude='**/src/dev/CliDevProxyServer.ts' --coverage.exclude='**/src/credentials/Broker*' --coverage.exclude='**/src/pairing/**' --coverage.exclude='**/src/application/commands/UpsertLocalBootstrapUserCommand.ts' --coverage.exclude='**/src/infrastructure/persistence/CodemationPostgres*.ts' --coverage.exclude='**/src/canvas/WorkflowCanvasStraightCountEdge.tsx' --coverage.exclude='**/src/canvas/WorkflowCanvasSymmetricForkEdge.tsx' --coverage.exclude='**/src/canvas/WorkflowCanvasSimpleIconGlyph.tsx'",
    "coverage:e2e": "vitest run --config tooling/vitest/e2e.config.ts --coverage --coverage.provider=v8 --coverage.reporter=lcov --coverage.reportsDirectory=coverage/raw/e2e --coverage.reportOnFailure --coverage.exclude='**/test/**' --coverage.exclude='**/prisma-generated/**' --coverage.exclude='**/*.config.{ts,mjs,js}' --coverage.exclude='**/src/canvas/WorkflowCanvasStraightCountEdge.tsx' --coverage.exclude='**/src/canvas/WorkflowCanvasSymmetricForkEdge.tsx' --coverage.exclude='**/src/canvas/WorkflowCanvasSimpleIconGlyph.tsx'",
    "coverage:browser": "timeout 30m pnpm --filter @codemation/host run test:browser || echo 'Browser coverage skipped (Playwright not installed or test failure)'",
    "coverage:merge": "lcov-result-merger 'coverage/raw/**/lcov.info' coverage/lcov.info",
    "dupcheck": "jscpd packages apps/test-dev apps/plugin-dev apps/docs",
    "antipatterns": "ast-grep scan --report-style short --off=no-double-assertion",
    "antipatterns:assertions": "ast-grep scan --report-style short --filter no-double-assertion",
    "prepare": "husky",
    "verdaccio": "verdaccio --config tooling/verdaccio/config.yaml",
    "local-release:publish": "node tooling/verdaccio/publish-local-registry.mjs",
    "local-release:smoke": "pnpm --filter create-codemation test:verdaccio-smoke",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:verify": "sh tooling/scripts/verify-changeset-coverage.sh"
  },
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@ast-grep/cli": "^0.41.1",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "4.0.18",
    "concurrently": "^9.2.1",
    "dependency-cruiser": "^17.4.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "knip": "^6.11.0",
    "lcov-result-merger": "^5.0.1",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3",
    "verdaccio": "^6.2.4",
    "vitest": "4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,cjs,js,jsx,json,md,yml,yaml,css,html}": "prettier --write"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@ast-grep/cli"
    ],
    "overrides": {
      "zod": "4.3.6"
    }
  }
}
