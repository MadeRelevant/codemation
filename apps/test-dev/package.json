{
  "name": "@codemation/test-dev",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "codemation": "tsx --tsconfig ../../tsconfig.codemation-tsx.json ../../packages/cli/src/bin.ts",
    "dev": "CODEMATION_DEV_MODE=framework pnpm codemation dev",
    "worker": "codemation-worker",
    "build": "pnpm --filter @codemation/core-nodes-gmail build && pnpm --filter @codemation/runtime-dev build && pnpm --filter @codemation/cli build && node ../../packages/cli/bin/codemation.js build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "echo \"(test placeholder)\""
  },
  "dependencies": {
    "@codemation/cli": "workspace:*",
    "@codemation/core": "workspace:*",
    "@codemation/core-nodes": "workspace:*",
    "@codemation/core-nodes-gmail": "workspace:*",
    "@codemation/eventbus-redis": "workspace:*",
    "@codemation/host": "workspace:*",
    "@codemation/node-example": "workspace:*",
    "@azure/ai-content-understanding": "^1.0.0",
    "@azure/core-auth": "^1.10.1",
    "@codemation/queue-bullmq": "workspace:*",
    "@codemation/worker-cli": "workspace:*",
    "dotenv": "^17.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
