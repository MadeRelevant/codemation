{
  "threshold": 1,
  "reporters": ["console"],
  "ignore": [
    "**/dist/**",
    "**/.next/**",
    "**/node_modules/**",
    "**/*.d.ts",
    "**/routeTree.gen.ts",
    "**/test/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/.codemation/**",
    "**/generated/**",
    "**/packages/create-codemation/templates/**"
  ],
  "absolute": true,
  "minLines": 10,
  "minTokens": 80,
  "mode": "mild",
  "format": ["typescript", "tsx"]
}
