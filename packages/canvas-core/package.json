{
  "name": "@codemation/canvas-core",
  "version": "0.0.1",
  "publishConfig": {
    "access": "public"
  },
  "author": "Made Relevant B.V.",
  "homepage": "https://www.maderelevant.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/MadeRelevant/codemation",
    "directory": "packages/canvas-core"
  },
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "changeset:verify": "pnpm --workspace-root run changeset:verify",
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test:unit": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@codemation/core": "workspace:*",
    "@codemation/host": "workspace:*",
    "@tanstack/react-query": "^5.90.21",
    "date-fns": "^4.1.0",
    "pretty-ms": "^9.3.0"
  },
  "sideEffects": false,
  "peerDependencies": {
    "@xyflow/react": "*",
    "elkjs": "*",
    "lucide-react": "*",
    "react": "*",
    "simple-icons": "*"
  },
  "devDependencies": {
    "@codemation/eslint-config": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.5",
    "@types/react": "*",
    "@types/react-dom": "^19.2.3",
    "elkjs": "^0.9.3",
    "eslint": "^10.0.3",
    "jsdom": "*",
    "lucide-react": "^0.577.0",
    "react-dom": "^19.0.0",
    "simple-icons": "^16.12.0",
    "tsdown": "^0.15.5",
    "typescript": "^5.9.3",
    "vitest": "4.0.18"
  }
}
