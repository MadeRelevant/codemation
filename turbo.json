{
  "$schema": "https://turbo.build/schema.json",
  "concurrency": "12",
  "globalPassThroughEnv": ["PORT", "AUTH_SECRET", "CODEMATION_DEV_GATEWAY_HTTP_PORT", "CODEMATION_LOG_LEVEL"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    }
  }
}
