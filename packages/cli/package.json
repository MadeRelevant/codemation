{
  "name": "@codemation/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "codemation": "./bin/codemation.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts src/bin.ts --out-dir dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@codemation/frontend": "workspace:*",
    "@codemation/next-host": "workspace:*",
    "chokidar": "^5.0.0",
    "reflect-metadata": "^0.2.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@codemation/eslint-config": "workspace:*",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "tsdown": "^0.15.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "tsx": ">=4.0.0"
  }
}
