{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["node"],
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/workflows/lib/**/*.ts",
    "src/workflows/print-hello-every-minute/**/*.ts",
    "src/workflows/starter/**/*.ts",
    "test/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules"]
}
