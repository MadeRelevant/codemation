{
  "name": "@codemation/core-nodes",
  "version": "0.0.25",
  "publishConfig": {
    "access": "public"
  },
  "author": "Made Relevant B.V.",
  "homepage": "https://www.maderelevant.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/MadeRelevant/codemation",
    "directory": "packages/core-nodes"
  },
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": {
        "import": "./src/index.ts",
        "require": "./dist/index.cjs"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "changeset:verify": "pnpm --workspace-root run changeset:verify",
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "pnpm --filter @codemation/core build && pnpm build && vitest run"
  },
  "dependencies": {
    "@codemation/core": "workspace:*",
    "@langchain/core": "^1.1.31",
    "@langchain/openai": "^1.2.12",
    "lucide-react": "^0.577.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "reflect-metadata": "^0.2.2",
    "tsdown": "^0.15.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "4.0.18",
    "zod": "^4.3.6"
  }
}
