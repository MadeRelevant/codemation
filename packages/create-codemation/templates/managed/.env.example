# Managed workspace identity — injected by the provisioner; do not edit by hand in production.
WORKSPACE_ID=
WORKSPACE_PAIRING_SECRET=

# Control-plane connectivity — injected by the provisioner.
CONTROL_PLANE_URL=
CONTROL_PLANE_JWKS_URL=
CONTROL_PLANE_ISSUER=
CP_WEB_ORIGIN=

# Public URL of this workspace's HTTP endpoint (used for redirect URLs and CORS).
CODEMATION_PUBLIC_BASE_URL=

# PostgreSQL database URL — provisioned automatically in managed deployments.
DATABASE_URL=

# Optional: BullMQ + Redis event bus.
# When set, CODEMATION_EXECUTION_MODE should be "queue".
# REDIS_URL=redis://127.0.0.1:6379
# CODEMATION_EXECUTION_MODE=queue
