# Default: embedded Postgres (PGlite) data under .codemation/pglite — DATABASE_URL is optional.
# Optional: use TCP PostgreSQL instead (postgresql:// or postgres://).
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/codemation

# Optional: BullMQ + Redis event bus. When set, DATABASE_URL must point to a shared PostgreSQL instance (not PGlite).
# REDIS_URL=redis://127.0.0.1:6379
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/codemation

# Local-development defaults for backend-owned auth/session cookies and credential encryption.
# Rotate these before sharing or deploying.
CODEMATION_CREDENTIALS_MASTER_KEY=codemation-local-dev-credentials-master-key
AUTH_SECRET=codemation-local-dev-auth-secret
