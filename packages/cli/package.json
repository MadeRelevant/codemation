{
  "name": "@codemation/cli",
  "version": "0.0.12",
  "publishConfig": {
    "access": "public"
  },
  "author": "Made Relevant B.V.",
  "homepage": "https://www.maderelevant.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/MadeRelevant/codemation",
    "directory": "packages/cli"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "codemation": "./bin/codemation.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsdown src/index.ts src/bin.ts --out-dir dist --watch",
    "build": "tsdown src/index.ts src/bin.ts --out-dir dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@codemation/host": "workspace:*",
    "@codemation/next-host": "workspace:*",
    "@hono/node-server": "^1.19.9",
    "bcryptjs": "^3.0.3",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "figlet": "^1.11.0",
    "hono": "^4.12.8",
    "http-proxy": "^1.18.1",
    "reflect-metadata": "^0.2.2",
    "typescript": "^5.9.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@codemation/eslint-config": "workspace:*",
    "@types/http-proxy": "^1.17.15",
    "@types/node": "^25.3.5",
    "@types/ws": "^8.18.1",
    "eslint": "^10.0.3",
    "tsdown": "^0.15.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "4.0.18"
  },
  "peerDependencies": {
    "tsx": ">=4.0.0"
  }
}
