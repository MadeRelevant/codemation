{
  "name": "create-codemation",
  "version": "0.0.9",
  "publishConfig": {
    "access": "public"
  },
  "author": "Made Relevant B.V.",
  "homepage": "https://www.maderelevant.com",
  "description": "Scaffold a Codemation consumer application (npm create codemation)",
  "keywords": [
    "codemation",
    "create-app",
    "scaffold",
    "cli"
  ],
  "license": "UNLICENSED",
  "type": "module",
  "bin": {
    "create-codemation": "./bin/create-codemation.js"
  },
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsdown src/bin.ts --out-dir dist",
    "dev": "tsdown src/bin.ts --out-dir dist --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:smoke": "node ./test/CreateCodemationSmoke.mjs",
    "test:packaged-smoke": "node ./test/CreateCodemationPackagedSmoke.mjs",
    "test:verdaccio-smoke": "node ./test/CreateCodemationVerdaccioSmoke.mjs",
    "test:interactive-verdaccio-smoke": "node ./test/CreateCodemationInteractiveVerdaccioSmoke.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@codemation/eslint-config": "workspace:*",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "tsdown": "^0.15.5",
    "typescript": "^5.9.3",
    "vitest": "4.0.18"
  }
}
