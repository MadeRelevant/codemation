{
  "name": "@codemation/test-dev",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:server": "nodemon --watch src --watch ../../packages --ext ts,tsx,mts,cts,js,mjs,json --exec \"CODEMATION_TS_RUNTIME=ts-node node --enable-source-maps --conditions=development --loader ts-node/esm --experimental-specifier-resolution=node src/server.ts\"",
    "dev:client": "vite dev",
    "start": "CODEMATION_TS_RUNTIME=ts-node node --enable-source-maps --conditions=development --loader ts-node/esm --experimental-specifier-resolution=node src/server.ts",
    "worker": "codemation-worker",
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "echo \"(test placeholder)\""
  },
  "dependencies": {
    "@codemation/core": "workspace:*",
    "@codemation/core-nodes": "workspace:*",
    "@codemation/core-nodes-gmail": "workspace:*",
    "@codemation/eventbus-redis": "workspace:*",
    "@codemation/frontend": "workspace:*",
    "@codemation/node-example": "workspace:*",
    "@codemation/queue-bullmq": "workspace:*",
    "@codemation/worker-cli": "workspace:*",
    "dotenv": "^17.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
