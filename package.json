{
  "name": "codemation",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "codemation": "tsx --tsconfig tsconfig.codemation-tsx.json packages/cli/src/bin.ts",
    "dev": "pnpm run dev:repo",
    "dev:docs": "pnpm --filter @codemation/docs dev",
    "dev:repo": "pnpm exec turbo run build --filter=@codemation/test-dev... --filter=!@codemation/next-host --filter=!@codemation/eslint-config && pnpm exec turbo run dev --filter=@codemation/test-dev... --filter=!@codemation/next-host --filter=!@codemation/eslint-config",
    "dev:consumer": "pnpm --filter @codemation/test-dev dev",
    "e2e:devserver": "pnpm exec turbo run build --filter=@codemation/e2e-app... --filter=!@codemation/next-host --filter=!@codemation/eslint-config && pnpm --filter @codemation/e2e-app dev",
    "e2e:serve-web": "pnpm --filter @codemation/e2e-app exec codemation serve web",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint && pnpm run dupcheck && pnpm run antipatterns",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "precommit": "pnpm lint && pnpm typecheck && pnpm run test:unit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo run build && pnpm run test:suites",
    "test:suites": "concurrently -m 2 -c auto -n unit,integration,ui,browser,e2e \"pnpm run test:unit\" \"pnpm run test:integration\" \"pnpm run test:ui\" \"pnpm run test:browser\" \"pnpm run test:e2e\"",
    "test:unit": "vitest run --config tooling/vitest/unit.config.ts",
    "test:integration": "vitest run --config tooling/vitest/integration.config.ts",
    "test:ui": "vitest run --config tooling/vitest/ui.config.ts",
    "test:browser": "timeout 15m pnpm --filter @codemation/host run test:browser",
    "test:e2e": "vitest run --config tooling/vitest/e2e.config.ts",
    "coverage": "pnpm run coverage:clean && concurrently -m 2 -c auto -n unit,integration,ui,browser,e2e \"pnpm run coverage:unit\" \"pnpm run coverage:integration\" \"pnpm run coverage:ui\" \"pnpm run coverage:browser\" \"pnpm run coverage:e2e\" && pnpm run coverage:merge",
    "coverage:clean": "pnpm exec rimraf coverage",
    "coverage:unit": "vitest run --config tooling/vitest/unit.config.ts --coverage --coverage.provider=v8 --coverage.reporter=lcov --coverage.reportsDirectory=coverage/raw/unit",
    "coverage:integration": "vitest run --config tooling/vitest/integration.config.ts --coverage --coverage.provider=v8 --coverage.reporter=lcov --coverage.reportsDirectory=coverage/raw/integration",
    "coverage:ui": "vitest run --config tooling/vitest/ui.config.ts --coverage --coverage.provider=v8 --coverage.reporter=lcov --coverage.reportsDirectory=coverage/raw/ui",
    "coverage:e2e": "vitest run --config tooling/vitest/e2e.config.ts --coverage --coverage.provider=v8 --coverage.reporter=lcov --coverage.reportsDirectory=coverage/raw/e2e",
    "coverage:browser": "timeout 15m pnpm --filter @codemation/host run test:browser",
    "coverage:merge": "lcov-result-merger 'coverage/raw/**/lcov.info' coverage/lcov.info",
    "dupcheck": "jscpd packages apps/test-dev apps/docs",
    "antipatterns": "ast-grep scan --report-style short --off=no-double-assertion",
    "antipatterns:assertions": "ast-grep scan --report-style short --filter no-double-assertion",
    "prepare": "husky",
    "verdaccio": "verdaccio --config tooling/verdaccio/config.yaml",
    "local-release:publish": "node tooling/verdaccio/publish-local-registry.mjs",
    "local-release:smoke": "pnpm --filter create-codemation test:verdaccio-smoke"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.41.1",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "4.0.18",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "jscpd": "^4.0.8",
    "lcov-result-merger": "^5.0.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3",
    "verdaccio": "^6.2.4",
    "vitest": "4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,cjs,js,jsx,json,md,yml,yaml,css,html}": "prettier --write"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@ast-grep/cli"
    ]
  }
}
