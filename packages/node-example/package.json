{
  "name": "@codemation/node-example",
  "version": "0.0.26",
  "publishConfig": {
    "access": "public"
  },
  "author": "Made Relevant B.V.",
  "homepage": "https://www.maderelevant.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/MadeRelevant/codemation",
    "directory": "packages/node-example"
  },
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": {
        "import": "./src/index.ts",
        "require": "./dist/index.cjs"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "changeset:verify": "pnpm --workspace-root run changeset:verify",
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "echo \"(test placeholder)\""
  },
  "dependencies": {
    "@codemation/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "tsdown": "^0.15.5",
    "typescript": "^5.9.3"
  }
}
