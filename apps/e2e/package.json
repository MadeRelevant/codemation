{
  "name": "@codemation/e2e-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "codemation": "tsx --tsconfig ../../tsconfig.codemation-tsx.json ../../packages/cli/src/bin.ts",
    "dev": "CODEMATION_DEV_MODE=framework pnpm codemation dev",
    "build": "pnpm --filter @codemation/runtime-dev build && pnpm --filter @codemation/cli build && node ../../packages/cli/bin/codemation.js build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "echo \"(e2e consumer — browser tests live in @codemation/host)\""
  },
  "dependencies": {
    "@codemation/cli": "workspace:*",
    "@codemation/core": "workspace:*",
    "@codemation/core-nodes": "workspace:*",
    "@codemation/host": "workspace:*",
    "@codemation/runtime-dev": "workspace:*",
    "dotenv": "^17.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
